<program> ::= <statement_list>

<statement_list> ::= <statement>
                   | <statement> <statement_list>

<statement> ::= <variable_declaration>
              | <assignment_statement>
              | <io_statement>
              | <control_flow_statement>
              | <function_declaration>
              | <function_return>
              | <function_call_statement>

<variable_declaration> ::= "Let" <identifier> "be" <type> "."

<type> ::= "integer"
         | "decimal"
         | "string"

<assignment_statement> ::= "Set" <lvalue> "to" <expression> "."
                         | "Increase" <lvalue> "by" <expression> "."
                         | "Decrease" <lvalue> "by" <expression> "."
                         | "Multiply" <lvalue> "by" <expression> "."
                         | "Divide" <lvalue> "by" <expression> "."

<lvalue> ::= <identifier>
           | <identifier> "atPosition" <expression>

<io_statement> ::= "Show" <expression> "."
                 | "Get" <type> "ask" <string_literal> "storeInto" <lvalue> "."

<control_flow_statement> ::= <if_statement>
                           | <loop_statement>

<if_statement> ::= "If" <condition> "then:" <block> <else_if_list> <else_part>

<else_if_list> ::= <empty>
                 | "Otherwise" "if" <condition> "then:" <block> <else_if_list>

<else_part> ::= <empty>
              | "Otherwise:" <block>

<loop_statement> ::= "Repeat" <expression> "iterations:" <block>
                   | "Foreach" <identifier> "in" <identifier> ":" <block>
                   | "While" <condition> ":" <block>

<block> ::= <statement_list>

<function_declaration> ::= "To" <identifier> "with" <identifier> ":" <block>
                         | "To" <identifier> ":" <block>

<function_return> ::= "Return" <expression> "."

<function_call_statement> ::= <function_call> "."

<block> ::= INDENT <statement_list> DEDENT

<function_declaration> ::= "To" <identifier> "with" <parameter_list> ":" <block>
                         | "To" <identifier> "with" "Nan" ":" <block>

<parameter_list> ::= <identifier> 
                   | <identifier> "and" <parameter_list>

<function_call_statement> ::= <function_call> "."

<function_call> ::= <identifier> "with" <argument_list>
                  | <identifier> "with" "Nan"

<argument_list> ::= <expression> 
                  | <expression> "and" <argument_list>

<factor> ::= <lvalue>
           | <function_call>
           | <number_literal>
           | <string_literal>
           | "(" <expression> ")"

<additive_op> ::= "add" | "subtract"

<multiplicative_op> ::= "times" | "divide" | "remainderOf" ... "dividedBy" 

<condition> ::= <bool_term>
              | <condition> "or" <bool_term>

<bool_term> ::= <bool_factor>
              | <bool_term> "and" <bool_factor>

<bool_factor> ::= <expression> <relational_op> <expression>
                | "not" <condition>
                | "(" <condition> ")"

<relational_op> ::= "equalsTo"
                  | "notEqualsTo"
                  | "greaterThan"
                  | "lessThan"
                  | "atLeast"
                  | "atMost"

<identifier> ::= [a-zA-Z_][a-zA-Z0-9_]*

<number_literal> ::= [0-9]+ 
                   | [0-9]+ "." [0-9]+

<string_literal> ::= '"' [^"]* '"'

<empty> ::=